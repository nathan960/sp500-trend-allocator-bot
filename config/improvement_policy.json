{
  "mode": "alpaca_direct_paper_research_first",
  "claude_may_modify_production_main": false,
  "claude_may_deploy_quantconnect": false,
  "claude_may_place_alpaca_orders": false,
  "claude_may_create_candidate_prs": true,
  "claude_may_auto_merge_strategy_changes": false,
  "claude_may_auto_promote_to_live": false,
  "min_paper_days_before_live_discussion": 14,
  "preferred_paper_days_before_live_discussion": 30,
  "allowed_auto_edit_paths": [
    "memory/",
    "docs/",
    "research/",
    "routines/",
    ".claude/commands/"
  ],
  "forbidden_auto_edit_paths": [
    "quantconnect/main.py",
    "config/strategy.json",
    "config/universe.json",
    "config/sector_map.json",
    ".env"
  ],
  "required_validation": [
    "compare_to_spy_buy_hold",
    "compare_to_bil",
    "drawdown_review",
    "turnover_and_fee_review",
    "paper_deployment_review",
    "no_unexpected_positions",
    "no_strategy_metadata_mismatch"
  ],
  "promotion_requires": {
    "human_approval": true,
    "paper_validation_days": 14
  }
}
